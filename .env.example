APP_NAME=足球赔率分析可视化系统
APP_HOST=127.0.0.1
APP_PORT=5001
DATABASE_URL=sqlite:///./football.db

# 推荐使用网页抓取版:
# - 赔率来源为 BetExplorer 首页抓取
# - 当前默认不接入实时比分抓取
DATA_MODE=betexplorer_scrape
LIVE_SCORE_MODE=off

# 免费档建议使用极保守轮询，避免触发 100 requests/day 限额
DISCOVERY_INTERVAL_SECONDS=43200
POLL_INTERVAL_SECONDS=10800
TRACKED_MARKETS_LIMIT=6
MARKET_WINDOW_HOURS=18
HISTORY_POINTS=240
PREMATCH_ODDS_REFRESH_SECONDS=43200
LIVE_ODDS_REFRESH_SECONDS=10800
PREMATCH_ODDS_MAX_PAGES=2
LIVE_ODDS_MAX_PAGES=2

LIVE_SCORE_INTERVAL_SECONDS=10800
LIVE_SCORE_EVENT_INTERVAL_SECONDS=10800
LIVE_SCORE_MATCH_WINDOW_MINUTES=240
LIVE_SCORE_EVENT_HISTORY_LIMIT=10
LIVE_SCORE_EVENT_MATCHES_LIMIT=1

# API-Football 免费 key
# 当前默认抓取版不会使用这组配置，保留仅作备用
API_FOOTBALL_KEY=
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io
API_FOOTBALL_TIMEZONE=Asia/Tokyo

# 可按需要收缩博彩公司列表和联赛列表，进一步降低请求量
PREFERRED_BOOKMAKERS=Bet365,William Hill,1xBet,Pinnacle,Unibet
TARGET_LEAGUE_IDS=
